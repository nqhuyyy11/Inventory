generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // ADMIN, STORE_MANAGER, INVENTORY_MANAGER, SALESPERSON, SUPPLIER
  permissions String?
  users       User[]
  createdAt   DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String?  @unique
  fullName  String
  phone     String?
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  
  // Relations
  assignments      UserLocation[]
  managedLocations Location[]     @relation("LocationManager")
  transactions     Transaction[]
  requestsCreated  InventoryRequest[]
  purchaseOrders   PurchaseOrder[]
  
  createdAt DateTime @default(now())
}

enum LocationType {
  WAREHOUSE
  STORE
}

model Location {
  id        Int          @id @default(autoincrement())
  name      String
  type      LocationType
  address   String?
  capacity  Int?
  managerId Int?
  manager   User?        @relation("LocationManager", fields: [managerId], references: [id])
  
  // Relations
  staffAssignments UserLocation[]
  inventory        Inventory[]
  transactions     Transaction[]
  
  requestsAsSource InventoryRequest[] @relation("RequestSource")
  requestsAsDest   InventoryRequest[] @relation("RequestDest")
  
  purchaseOrders   PurchaseOrder[]
  
  createdAt DateTime @default(now())
}

model UserLocation {
  id         Int      @id @default(autoincrement())
  userId     Int
  locationId Int
  startDate  DateTime @default(now())
  endDate    DateTime?
  
  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
  
  @@unique([userId, locationId])
}

model Supplier {
  id          Int             @id @default(autoincrement())
  name        String
  contactInfo String?
  orders      PurchaseOrder[]
  products    SupplierProduct[]
  createdAt   DateTime        @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  category    String?
  unit        String
  
  // Relations
  inventory        Inventory[]
  transactionItems TransactionItem[]
  requestItems     RequestItem[]
  purchaseItems    PurchaseOrderItem[]
  supplierProducts SupplierProduct[]
  
  createdAt DateTime @default(now())
}

// Supplier Pricing/Availability
model SupplierProduct {
  id         Int      @id @default(autoincrement())
  supplierId Int
  productId  Int
  price      Float
  isAvailable Boolean @default(true)
  
  supplier Supplier @relation(fields: [supplierId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  
  @@unique([supplierId, productId])
}

model Inventory {
  id               Int       @id @default(autoincrement())
  locationId       Int
  productId        Int
  quantity         Int       @default(0)
  costPrice        Float     @default(0)
  sellingPrice     Float     @default(0)
  expirationDate   DateTime?
  dynamicThreshold Int?      // Ngưỡng cảnh báo tự động
  
  location Location @relation(fields: [locationId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  
  @@unique([locationId, productId, expirationDate]) // Track expiration per location/product
}

enum TransactionType {
  IMPORT
  EXPORT
  SALE
  RETURN
  DAMAGE
}

model Transaction {
  id         Int             @id @default(autoincrement())
  locationId Int
  type       TransactionType
  createdById Int
  totalValue Float           @default(0)
  notes      String?
  
  location  Location          @relation(fields: [locationId], references: [id])
  createdBy User              @relation(fields: [createdById], references: [id])
  items     TransactionItem[]
  
  createdAt DateTime @default(now())
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId Int
  productId     Int
  quantity      Int
  price         Float
  
  transaction Transaction @relation(fields: [transactionId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model InventoryRequest {
  id               Int           @id @default(autoincrement())
  sourceLocationId Int?          
  destLocationId   Int           
  status           RequestStatus @default(PENDING)
  createdById      Int
  notes            String?
  
  sourceLocation Location?     @relation("RequestSource", fields: [sourceLocationId], references: [id])
  destLocation   Location      @relation("RequestDest", fields: [destLocationId], references: [id])
  createdBy      User          @relation(fields: [createdById], references: [id])
  items          RequestItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RequestItem {
  id        Int     @id @default(autoincrement())
  requestId Int
  productId Int
  quantity  Int
  
  request InventoryRequest @relation(fields: [requestId], references: [id])
  product Product          @relation(fields: [productId], references: [id])
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  CONFIRMED
  REJECTED
  DELIVERED
}

model PurchaseOrder {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  warehouseId Int
  status      POStatus @default(DRAFT)
  createdById Int
  totalValue  Float    @default(0)
  
  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  warehouse Location            @relation(fields: [warehouseId], references: [id])
  createdBy User                @relation(fields: [createdById], references: [id])
  items     PurchaseOrderItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrderItem {
  id        Int   @id @default(autoincrement())
  poId      Int
  productId Int
  quantity  Int
  price     Float
  
  po      PurchaseOrder @relation(fields: [poId], references: [id])
  product Product       @relation(fields: [productId], references: [id])
}
